  },
  "dependencies": {
    "aws-sdk": "^2.1692.0",
    "bcrypt": "^5.1.1",
    "express": "^4.21.1",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mock-aws-s3": "^4.0.2",
    "multer": "^1.4.5-lts.1",
    "nock": "^13.5.6",
